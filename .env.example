# Google OAuth
GOOGLE_CLIENT_ID=your_google_client_id
GOOGLE_CLIENT_SECRET=your_google_client_secret
SESSION_SECRET=your_session_secret

# Database
DATABASE_URL=postgresql://user:password@localhost:5432/agent_portal

# Sentry Error Tracking
SENTRY_DSN=your_sentry_dsn

# PostHog Analytics
POSTHOG_API_KEY=your_posthog_api_key

# OpenClaw Plugin Webhook (portal → OpenClaw inbound handler)
# When a user sends a message to a DM channel, the portal server POSTs the
# event to this URL so the OpenClaw plugin's onInbound() can route it to
# the active agent session.
# Default: http://127.0.0.1:3001/inbound  (matches plugin default webhookPort)
WEBHOOK_URL=http://127.0.0.1:3001/inbound
# HMAC key used to sign the X-Portal-Signature: sha256=<hex> header.
# Must match WEBHOOK_SECRET in the OpenClaw plugin config.
WEBHOOK_SECRET=your_webhook_secret
