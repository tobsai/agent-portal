{
  "name": "openclaw-channel-agent-portal",
  "version": "1.0.0",
  "description": "Agent Portal channel plugin for OpenClaw",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "scripts": {
    "build": "tsc --outDir dist --declaration --module commonjs --target es2020 --esModuleInterop index.ts"
  },
  "keywords": [
    "openclaw",
    "channel-plugin",
    "agent-portal"
  ],
  "openclaw": {
    "extensions": [
      "./dist/index.js"
    ],
    "channel": {
      "id": "portal",
      "label": "Agent Portal",
      "selectionLabel": "Agent Portal",
      "detailLabel": "Agent Portal iOS",
      "blurb": "Self-hosted Agent Portal channel for OpenClaw.",
      "exposure": {
        "configured": true,
        "setup": false,
        "docs": false
      }
    }
  },
  "license": "MIT",
  "author": "",
  "type": "commonjs",
  "devDependencies": {
    "@types/node": "^26.0.0",
    "typescript": "^5.9.3"
  }
}
